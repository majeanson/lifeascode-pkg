<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 390 520" width="390" height="520">
  <!-- App background -->
  <rect width="390" height="520" fill="#f9f7f2"/>

  <!-- Phone frame shadow -->
  <rect x="20" y="20" width="350" height="480" rx="24" ry="24" fill="#e8e3db" opacity="0.6"/>
  <!-- Phone frame -->
  <rect x="16" y="16" width="350" height="480" rx="24" ry="24" fill="#ffffff" stroke="#e0dbd3" stroke-width="1.5"/>

  <!-- Header bar -->
  <rect x="16" y="16" width="350" height="52" rx="24" ry="24" fill="#ffffff"/>
  <rect x="16" y="44" width="350" height="24" fill="#ffffff"/>
  <text x="191" y="46" font-family="Georgia, serif" font-size="15" font-weight="700" fill="#1a1a2e" text-anchor="middle">Count the Dots</text>

  <!-- Dot card -->
  <rect x="50" y="84" width="282" height="200" rx="16" ry="16" fill="#f9f7f2" stroke="#e0dbd3" stroke-width="1.5"/>

  <!-- Dots — 7 dots in a recognizable pattern -->
  <!-- Row 1: 3 dots -->
  <circle cx="128" cy="144" r="13" fill="#7ec8a4"/>
  <circle cx="191" cy="144" r="13" fill="#7ec8a4"/>
  <circle cx="254" cy="144" r="13" fill="#7ec8a4"/>
  <!-- Row 2: 1 dot center -->
  <circle cx="191" cy="184" r="13" fill="#7ec8a4"/>
  <!-- Row 3: 3 dots -->
  <circle cx="128" cy="224" r="13" fill="#7ec8a4"/>
  <circle cx="191" cy="224" r="13" fill="#7ec8a4"/>
  <circle cx="254" cy="224" r="13" fill="#7ec8a4"/>

  <!-- How many? label -->
  <text x="191" y="310" font-family="Georgia, serif" font-size="14" fill="#6b6570" text-anchor="middle">How many dots?</text>

  <!-- Number buttons — 4 choices -->
  <!-- Button 5 (wrong, red) -->
  <rect x="50" y="330" width="120" height="56" rx="12" ry="12" fill="#fee2e2" stroke="#fca5a5" stroke-width="1.5"/>
  <text x="110" y="364" font-family="Georgia, serif" font-size="28" font-weight="700" fill="#ef4444" text-anchor="middle">5</text>

  <!-- Button 7 (correct, green) -->
  <rect x="182" y="330" width="120" height="56" rx="12" ry="12" fill="#dcfce7" stroke="#86efac" stroke-width="1.5"/>
  <text x="242" y="364" font-family="Georgia, serif" font-size="28" font-weight="700" fill="#16a34a" text-anchor="middle">7</text>

  <!-- Button 3 -->
  <rect x="50" y="402" width="120" height="56" rx="12" ry="12" fill="#ffffff" stroke="#e0dbd3" stroke-width="1.5"/>
  <text x="110" y="436" font-family="Georgia, serif" font-size="28" font-weight="700" fill="#1a1a2e" text-anchor="middle">3</text>

  <!-- Button 9 -->
  <rect x="182" y="402" width="120" height="56" rx="12" ry="12" fill="#ffffff" stroke="#e0dbd3" stroke-width="1.5"/>
  <text x="242" y="436" font-family="Georgia, serif" font-size="28" font-weight="700" fill="#1a1a2e" text-anchor="middle">9</text>

  <!-- Bottom label -->
  <text x="191" y="490" font-family="Georgia, serif" font-size="11" fill="#c4bfb8" text-anchor="middle">Quiet Minds</text>
</svg>
