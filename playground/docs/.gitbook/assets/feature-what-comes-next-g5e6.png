<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 390 520" width="390" height="520">
  <rect width="390" height="520" fill="#f9f7f2"/>
  <rect x="20" y="20" width="350" height="480" rx="24" ry="24" fill="#e8e3db" opacity="0.6"/>
  <rect x="16" y="16" width="350" height="480" rx="24" ry="24" fill="#ffffff" stroke="#e0dbd3" stroke-width="1.5"/>
  <rect x="16" y="16" width="350" height="52" rx="24" ry="24" fill="#ffffff"/>
  <rect x="16" y="44" width="350" height="24" fill="#ffffff"/>
  <text x="191" y="46" font-family="Georgia, serif" font-size="15" font-weight="700" fill="#1a1a2e" text-anchor="middle">What Comes Next?</text>

  <!-- Pattern instruction -->
  <text x="191" y="92" font-family="Georgia, serif" font-size="13" fill="#6b6570" text-anchor="middle">What continues the pattern?</text>

  <!-- Pattern row: circle, square, circle, square, ? -->
  <!-- Cell sizes: 5 cells across, each ~60px wide with small gaps -->

  <!-- Circle 1 -->
  <rect x="30" y="108" width="60" height="60" rx="10" ry="10" fill="#f9f7f2" stroke="#e0dbd3" stroke-width="1.5"/>
  <circle cx="60" cy="138" r="18" fill="none" stroke="#7ec8a4" stroke-width="3"/>

  <!-- Square 1 -->
  <rect x="99" y="108" width="60" height="60" rx="10" ry="10" fill="#f9f7f2" stroke="#e0dbd3" stroke-width="1.5"/>
  <rect x="117" y="121" width="24" height="24" fill="none" stroke="#58a6ff" stroke-width="3"/>

  <!-- Circle 2 -->
  <rect x="168" y="108" width="60" height="60" rx="10" ry="10" fill="#f9f7f2" stroke="#e0dbd3" stroke-width="1.5"/>
  <circle cx="198" cy="138" r="18" fill="none" stroke="#7ec8a4" stroke-width="3"/>

  <!-- Square 2 -->
  <rect x="237" y="108" width="60" height="60" rx="10" ry="10" fill="#f9f7f2" stroke="#e0dbd3" stroke-width="1.5"/>
  <rect x="255" y="121" width="24" height="24" fill="none" stroke="#58a6ff" stroke-width="3"/>

  <!-- ? cell -->
  <rect x="306" y="108" width="60" height="60" rx="10" ry="10" fill="#fef9c3" stroke="#fde047" stroke-width="2"/>
  <text x="336" y="146" font-family="Georgia, serif" font-size="28" font-weight="700" fill="#ca8a04" text-anchor="middle">?</text>

  <!-- Arrow showing pattern continues -->
  <text x="191" y="198" font-family="Georgia, serif" font-size="12" fill="#6b6570" text-anchor="middle">○ □ ○ □ …</text>

  <!-- 3 answer choices -->
  <text x="191" y="228" font-family="Georgia, serif" font-size="13" fill="#1a1a2e" text-anchor="middle" font-weight="600">Choose the next shape</text>

  <!-- Choice 1: Triangle (wrong) -->
  <rect x="46" y="244" width="90" height="80" rx="12" ry="12" fill="#ffffff" stroke="#e0dbd3" stroke-width="1.5"/>
  <polygon points="91,260 114,296 68,296" fill="none" stroke="#1a1a2e" stroke-width="2.5"/>

  <!-- Choice 2: Circle (CORRECT, green) -->
  <rect x="152" y="244" width="90" height="80" rx="12" ry="12" fill="#dcfce7" stroke="#86efac" stroke-width="1.5"/>
  <circle cx="197" cy="284" r="22" fill="none" stroke="#16a34a" stroke-width="3"/>

  <!-- Choice 3: Star (wrong) -->
  <rect x="258" y="244" width="90" height="80" rx="12" ry="12" fill="#ffffff" stroke="#e0dbd3" stroke-width="1.5"/>
  <polygon points="303,252 307,268 324,268 311,278 316,294 303,284 290,294 295,278 282,268 299,268" fill="none" stroke="#1a1a2e" stroke-width="2"/>

  <!-- After correct — pattern shown complete -->
  <rect x="46" y="348" width="292" height="68" rx="10" ry="10" fill="#f0fdf4" stroke="#86efac" stroke-width="1"/>
  <text x="192" y="373" font-family="Georgia, serif" font-size="13" fill="#16a34a" text-anchor="middle" font-weight="600">Correct!</text>
  <text x="192" y="393" font-family="Georgia, serif" font-size="12" fill="#4ade80" text-anchor="middle">circle · square · circle · square · circle</text>

  <text x="191" y="490" font-family="Georgia, serif" font-size="11" fill="#c4bfb8" text-anchor="middle">Quiet Minds</text>
</svg>
