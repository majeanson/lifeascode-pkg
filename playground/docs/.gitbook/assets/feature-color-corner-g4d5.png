<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 390 520" width="390" height="520">
  <rect width="390" height="520" fill="#f9f7f2"/>
  <rect x="20" y="20" width="350" height="480" rx="24" ry="24" fill="#e8e3db" opacity="0.6"/>
  <rect x="16" y="16" width="350" height="480" rx="24" ry="24" fill="#ffffff" stroke="#e0dbd3" stroke-width="1.5"/>
  <rect x="16" y="16" width="350" height="52" rx="24" ry="24" fill="#ffffff"/>
  <rect x="16" y="44" width="350" height="24" fill="#ffffff"/>
  <text x="191" y="46" font-family="Georgia, serif" font-size="15" font-weight="700" fill="#1a1a2e" text-anchor="middle">Color Corner</text>

  <!-- Color name target -->
  <text x="191" y="100" font-family="Georgia, serif" font-size="30" font-weight="700" fill="#1a1a2e" text-anchor="middle">Blue</text>
  <text x="191" y="122" font-family="Georgia, serif" font-size="13" fill="#6b6570" text-anchor="middle">Tap the right color swatch</text>

  <!-- Swatch 1: Red (wrong) -->
  <rect x="46" y="140" width="138" height="78" rx="14" ry="14" fill="#ef4444"/>
  <text x="115" y="184" font-family="Georgia, serif" font-size="16" font-weight="700" fill="#ffffff" text-anchor="middle">Red</text>

  <!-- Swatch 2: Blue (CORRECT, with green border) -->
  <rect x="200" y="140" width="138" height="78" rx="14" ry="14" fill="#3b82f6" stroke="#16a34a" stroke-width="3"/>
  <text x="269" y="184" font-family="Georgia, serif" font-size="16" font-weight="700" fill="#ffffff" text-anchor="middle">Blue</text>
  <!-- Check mark -->
  <circle cx="320" cy="148" r="12" fill="#16a34a"/>
  <polyline points="314,148 319,153 326,143" fill="none" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>

  <!-- Swatch 3: Yellow (wrong) -->
  <rect x="46" y="234" width="138" height="78" rx="14" ry="14" fill="#eab308"/>
  <text x="115" y="278" font-family="Georgia, serif" font-size="16" font-weight="700" fill="#1a1a2e" text-anchor="middle">Yellow</text>

  <!-- Swatch 4: Purple (wrong) -->
  <rect x="200" y="234" width="138" height="78" rx="14" ry="14" fill="#a855f7"/>
  <text x="269" y="278" font-family="Georgia, serif" font-size="16" font-weight="700" fill="#ffffff" text-anchor="middle">Purple</text>

  <!-- Callout: name always visible -->
  <rect x="46" y="334" width="292" height="52" rx="10" ry="10" fill="#f0fdf4" stroke="#86efac" stroke-width="1"/>
  <text x="192" y="357" font-family="Georgia, serif" font-size="12" fill="#16a34a" text-anchor="middle" font-weight="600">Color name is always shown inside the swatch</text>
  <text x="192" y="375" font-family="Georgia, serif" font-size="11" fill="#4ade80" text-anchor="middle">— so colorblind children can play too</text>

  <text x="191" y="490" font-family="Georgia, serif" font-size="11" fill="#c4bfb8" text-anchor="middle">Quiet Minds</text>
</svg>
